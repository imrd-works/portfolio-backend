# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token
# Your numeric chat id (get it from @userinfobot or the getUpdates API)
TELEGRAM_CHAT_ID=123456789

# --- CORS ---
# Origin of the portfolio site allowed to call this API.
# Use a comma-separated list for several, or * to allow any origin.
ALLOWED_ORIGIN=https://your-portfolio-domain.ru

# --- Anti-self-submission (optional) ---
# Visitors must leave THEIR contacts, not yours — these are rejected if pasted.
OWNER_EMAIL=imld.works@yandex.ru
OWNER_TELEGRAM=@IIMRD

# --- Local dev only ---
PORT=3000
